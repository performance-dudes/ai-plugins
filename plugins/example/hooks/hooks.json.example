{
  "_comment": "Rename to hooks.json to activate. Hooks run automatically — review before enabling. Shows two event types: PreToolUse (before a tool runs, can block) and PostToolUse (after it runs, sees the result).",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/example-pretooluse.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/example-posttooluse.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

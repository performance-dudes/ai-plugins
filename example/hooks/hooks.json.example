{
  "_comment": "Rename to hooks.json to activate. Hooks run automatically — review before enabling.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/example-pretooluse.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
